DJANGO_SECRET_KEY=replace_with_new_secret_key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-username.pythonanywhere.com,your-username.eu.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-username.pythonanywhere.com,https://your-username.eu.pythonanywhere.com
DJANGO_USE_WHITENOISE=False

# Optional mail settings
DJANGO_EMAIL_BACKEND=django.core.mail.backends.dummy.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_DEFAULT_FROM_EMAIL=no-reply@example.com
